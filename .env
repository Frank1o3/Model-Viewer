# ── Python runtime ─────────────────────────────
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
PYTHONUTF8=1
PYTHONFAULTHANDLER=1

# ── Paths ───────────────────────────────────────
PYTHONPATH=src

# ── Pytest ──────────────────────────────────────
PYTEST_ADDOPTS="--tb=short -q"

# ── Mypy ────────────────────────────────────────
MYPY_CACHE_DIR=.cache/mypy
